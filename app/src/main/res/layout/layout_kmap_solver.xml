<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#121212"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="K-Map Solver (4 Variables)"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Manual Input Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Input Manual (Contoh: ABC + A'B'):"
        android:textColor="#B3FFFFFF"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etManualInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1AFFFFFF"
        android:hint="Ketik ekspresi di sini..."
        android:padding="12dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#4DFFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"
        android:inputType="textNoSuggestions" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A,B \ C,D"
        android:textColor="#00E5FF"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <!-- K-Map Grid 4x4 -->
    <GridLayout
        android:id="@+id/kmapGrid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:columnCount="4"
        android:rowCount="4"
        android:background="#333333"
        android:padding="2dp">
        <!-- 16 Cells will be added programmatically -->
    </GridLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hasil Penyederhanaan (SOP):"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/btnKMapStep"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP"
            android:textColor="#FFD600"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvKMapResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A00E5FF"
        android:padding="16dp"
        android:text="F = 0"
        android:textColor="#00E5FF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnResetKMap"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RESET TABLE"
        android:textColor="#FF5252"
        android:layout_gravity="end"
        android:layout_marginTop="16dp"/>

</LinearLayout>

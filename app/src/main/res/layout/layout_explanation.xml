<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F111A"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Handle Bar (Indicator) -->
        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:background="#2E3243"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:backgroundTint="#4DB6AC"
            android:alpha="0.5" />

        <TextView
            android:id="@+id/tv_expl_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Analisis Perhitungan"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:letterSpacing="0.02" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pelajari bagaimana sistem memecah logika angka Anda"
            android:textColor="#808B96"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <!-- Mode Selector -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#1A1D2D"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#2E3243"
            app:strokeWidth="1dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                app:checkedButton="@+id/btn_mode_simple"
                app:selectionRequired="true"
                app:singleSelection="true">

                <Button
                    android:id="@+id/btn_mode_complex"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:text="Complex"
                    android:textColor="#B0B3B8"
                    android:textSize="12sp"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_mode_simple"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:text="Simple"
                    android:textColor="#B0B3B8"
                    android:textSize="12sp"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_mode_short"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:text="Shortway"
                    android:textColor="#B0B3B8"
                    android:textSize="12sp"
                    android:textAllCaps="false" />

            </com.google.android.material.button.MaterialButtonToggleGroup>
        </com.google.android.material.card.MaterialCardView>

        <!-- Container Langkah-langkah -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:layout_marginTop="16dp"
            android:scrollbarThumbVertical="@android:color/transparent">

            <LinearLayout
                android:id="@+id/steps_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:divider="?android:attr/dividerVertical"
                android:showDividers="middle" />
        </androidx.core.widget.NestedScrollView>

        <!-- Footer / Action -->
        <Button
            android:id="@+id/btn_close_expl"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Selesai Belajar"
            android:backgroundTint="#00E5FF"
            android:textColor="#000000"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="16dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

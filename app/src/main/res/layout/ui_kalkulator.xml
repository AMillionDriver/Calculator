<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true"
    android:layoutDirection="ltr">

    <!-- Header / Top Navigation -->
    <LinearLayout
        android:id="@+id/linearLayout"
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btn_kurs"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:text="@string/Kurs"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_weight"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:text="@string/Weight"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_programmer"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:text="Programmer"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_settings"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1.2"
            android:backgroundTint="#00E5FF"
            android:text="@string/settings"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:descendantFocusability="beforeDescendants"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <!-- Display Area -->
            <LinearLayout
                android:id="@+id/linearLayout3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="bottom|end"
                android:minHeight="280dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingBottom="24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <EditText
                    android:id="@+id/tv_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:cursorVisible="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="end"
                    android:inputType="textNoSuggestions"
                    android:paddingBottom="8dp"
                    android:textColor="#B3FFFFFF"
                    android:textSize="32sp" />

                <TextView
                    android:id="@+id/tv_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autoSizeMaxTextSize="72sp"
                    android:autoSizeMinTextSize="24sp"
                    android:autoSizeTextType="uniform"
                    android:gravity="end"
                    android:maxLines="1"
                    android:text="@string/Zero"
                    android:textColor="#FFFFFF"
                    android:textSize="72sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Scientific Keypad -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/scientificGridLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/linearLayout3">

                <Button android:id="@+id/btn_kurung_buka" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="(" android:textColor="#4DB6AC" android:textSize="18sp" />
                <Button android:id="@+id/btn_kurung_tutup" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text=")" android:textColor="#4DB6AC" android:textSize="18sp" />
                <Button android:id="@+id/btn_akar" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="√" android:textColor="#4DB6AC" android:textSize="18sp" />
                <Button android:id="@+id/btn_pangkat" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="^" android:textColor="#4DB6AC" android:textSize="18sp" />
                <Button android:id="@+id/btn_sin" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="sin" android:textColor="#4DB6AC" android:textSize="16sp" />
                <Button android:id="@+id/btn_cos" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="cos" android:textColor="#4DB6AC" android:textSize="16sp" />
                <Button android:id="@+id/btn_tan" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="tan" android:textColor="#4DB6AC" android:textSize="16sp" />
                <Button android:id="@+id/btn_log" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="log" android:textColor="#4DB6AC" android:textSize="16sp" />
                <Button android:id="@+id/btn_ln" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="ln" android:textColor="#4DB6AC" android:textSize="16sp" />
                <Button android:id="@+id/btn_pi" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="π" android:textColor="#4DB6AC" android:textSize="18sp" />
                <Button android:id="@+id/btn_e" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="e" android:textColor="#4DB6AC" android:textSize="18sp" />
                <Button android:id="@+id/btn_inv" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="0dp" android:layout_height="56dp" android:text="±" android:textColor="#4DB6AC" android:textSize="18sp" />

                <androidx.constraintlayout.helper.widget.Flow
                    android:id="@+id/flowScientific"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flow_horizontalGap="4dp"
                    app:flow_maxElementsWrap="4"
                    app:flow_verticalGap="4dp"
                    app:flow_wrapMode="aligned"
                    app:layout_constraintTop_toTopOf="parent"
                    app:constraint_referenced_ids="btn_kurung_buka,btn_kurung_tutup,btn_akar,btn_pangkat,btn_sin,btn_cos,btn_tan,btn_log,btn_ln,btn_pi,btn_e,btn_inv" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Mode Switcher -->

            <!-- Main Keypad -->

            <FrameLayout
                android:id="@+id/mode_switcher_container"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/scientificGridLayout">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginHorizontal="64dp"
                    android:background="#1AFFFFFF" />

                <ImageView
                    android:id="@+id/btn_history"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="History"
                    android:focusable="true"
                    android:padding="12dp"
                    android:src="@drawable/clock_rotate_left_solid_full"
                    app:tint="#00E5FF" />

                <Button
                    android:id="@+id/btn_mode_switcher"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="72dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:backgroundTint="#1A4DB6AC"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="⌃"
                    android:textColor="#4DB6AC"
                    android:textSize="22sp"
                    app:cornerRadius="18dp" />
            </FrameLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/gridLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/mode_switcher_container"
                app:layout_constraintVertical_bias="0.0"
                tools:layout_editor_absoluteX="0dp">

                <Button
                    android:id="@+id/btn_c"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/c"
                    android:textColor="#FF5252"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_persen"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Percent"
                    android:textColor="#4DB6AC"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_backspace"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Backspace"
                    android:textColor="#4DB6AC"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_bagi"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/perbagian"
                    android:textColor="#4DB6AC"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_7"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Number7"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_8"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Number8"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_9"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Number9"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_kali"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/perkalian"
                    android:textColor="#4DB6AC"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_4"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Number4"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_5"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Number5"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_6"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Number6"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_kurang"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/perkurangan"
                    android:textColor="#4DB6AC"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_1"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Number1"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_2"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Number2"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_3"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Number3"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_tambah"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/pertambahan"
                    android:textColor="#56B6AC"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_nolnol"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/DoubleZero"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_0"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Zero"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_koma"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Coma"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp" />

                <Button
                    android:id="@+id/btn_equal"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:text="@string/Equal"
                    android:textColor="@android:color/holo_orange_dark"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <androidx.constraintlayout.helper.widget.Flow
                    android:id="@+id/flowMain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="btn_c,btn_persen,btn_backspace,btn_bagi,btn_7,btn_8,btn_9,btn_kali,btn_4,btn_5,btn_6,btn_kurang,btn_1,btn_2,btn_3,btn_tambah,btn_nolnol,btn_0,btn_koma,btn_equal"
                    app:flow_horizontalGap="4dp"
                    app:flow_maxElementsWrap="4"
                    app:flow_verticalGap="4dp"
                    app:flow_wrapMode="aligned"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

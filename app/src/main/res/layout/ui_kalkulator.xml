<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="408dp"
        android:layout_height="398dp"
        android:columnCount="4"
        android:padding="16dp"
        android:rowCount="5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Baris 1 -->
        <Button
            android:id="@+id/btn_c"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/c"
            android:textColor="#4DB6AC"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_persen"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Percent"
            android:textColor="#4DB6AC"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_backspace"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Backspace"
            android:textColor="#4DB6AC"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_bagi"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Plus"
            android:textColor="#4DB6AC"
            android:textSize="35sp" />

        <!-- Baris 2 -->
        <Button
            android:id="@+id/btn_7"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Number7"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_8"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Number8"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_9"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Number9"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_kali"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Multiple"
            android:textColor="#4DB6AC"
            android:textSize="35sp" />

        <!-- Baris 3 -->
        <Button
            android:id="@+id/btn_4"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Number4"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_5"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Number5"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_6"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Number6"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_kurang"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Minus"
            android:textColor="#4DB6AC"
            android:textSize="35sp" />

        <!-- Baris 4 -->
        <Button
            android:id="@+id/btn_1"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Number1"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_2"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Number2"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_3"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Number3"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_tambah"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Divided"
            android:textColor="#4DB6AC"
            android:textSize="35sp" />

        <!-- Baris 5 -->
        <Button
            android:id="@+id/btn_nolnol"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/DoubleZero"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_0"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Zero"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_koma"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Coma"
            android:textColor="#FFFFFF"
            android:textSize="35sp" />

        <Button
            android:id="@+id/btn_equal"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:text="@string/Equal"
            android:textColor="#4DB6AC"
            android:textSize="35sp" />
    </GridLayout>

    <LinearLayout
        android:id="@+id/linearLayout"
        style="?android:attr/buttonBarStyle"
        android:layout_width="409dp"
        android:layout_height="47dp"
        android:background="@color/white"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.052">

        <Button
            android:id="@+id/btn_back"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:backgroundTint="@color/white"
            android:text="@string/Back"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_kurs"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:backgroundTint="@color/white"
            android:text="@string/Kurs"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_weight"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="90dp"
            android:layout_height="40dp"
            android:backgroundTint="@color/white"
            android:text="@string/Weight"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_settings"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="110dp"
            android:layout_height="40dp"
            android:backgroundTint="@color/white"
            android:text="@string/Settings"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayout3"
        android:layout_width="389dp"
        android:layout_height="248dp"
        android:gravity="bottom|end"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toTopOf="@+id/gridLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout"
        app:layout_constraintVertical_bias="0.5">

        <TextView
            android:id="@+id/tv_input"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#80FFFFFF"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="35dp"
            android:text="@string/ValueZero"
            android:textColor="#FFFFFF"
            android:textSize="48sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>